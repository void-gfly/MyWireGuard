<Window x:Class="MyWireGuard.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="MyWireGuard"
        Height="720"
        Width="1180"
        MinHeight="600"
        MinWidth="960"
        Background="{StaticResource WindowBrush}"
        FontFamily="Microsoft YaHei UI"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True">

    <Window.Resources>
        <Style x:Key="TopNavItemStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="NavBg"
                                Background="Transparent"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="NavBg" Property="Background" Value="{StaticResource NavItemActiveBrush}" />
                                <Setter TargetName="NavBg" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="NavBg" Property="Background" Value="{StaticResource NavItemHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ShellStatusPillStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelElevatedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="5" />
            <Setter Property="Padding" Value="9,4" />
            <Setter Property="Margin" Value="8,0,0,0" />
        </Style>

        <Style x:Key="PanelCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        </Style>

        <Style x:Key="InfoLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="Margin" Value="0,0,0,3" />
        </Style>

        <Style x:Key="InfoValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="MetricChipStyle" TargetType="Border" BasedOn="{StaticResource PanelCardStyle}">
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>

        <Style x:Key="MetricValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,7,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="CompactBadgeBorderStyle" TargetType="Border">
            <Setter Property="Padding" Value="7,1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="MinWidth" Value="42" />
            <Setter Property="Height" Value="22" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Background" Value="#334155" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="success">
                    <Setter Property="Background" Value="#16A34A" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="warning">
                    <Setter Property="Background" Value="#D97706" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="danger">
                    <Setter Property="Background" Value="#DC2626" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="neutral">
                    <Setter Property="Background" Value="#475569" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CompactBadgeTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="9" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="TunnelTabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled">
                            <TabPanel IsItemsHost="True"
                                      Margin="0"
                                      Background="Transparent" />
                        </ScrollViewer>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TunnelTabItemStyle" TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="MinWidth" Value="116" />
            <Setter Property="MaxWidth" Value="190" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBg"
                                Margin="0,0,8,0"
                                Padding="{TemplateBinding Padding}"
                                Background="{StaticResource PanelElevatedBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              ContentSource="Header"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBg" Property="Background" Value="{StaticResource NavItemActiveBrush}" />
                                <Setter TargetName="TabBg" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBg" Property="Background" Value="{StaticResource NavItemHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Application shell bar -->
        <Border Grid.Row="0"
                Background="{StaticResource SidebarBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="14,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Border Width="28"
                            Height="28"
                            CornerRadius="7"
                            Background="{StaticResource AccentBrush}"
                            Margin="0,0,10,0">
                        <TextBlock Text="WG"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Foreground="#052E16"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="MyWireGuard"
                                   FontSize="15"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="WireGuard VPN 客户端"
                                   FontSize="10"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <RadioButton Style="{StaticResource TopNavItemStyle}"
                                 GroupName="MainNav"
                                 IsChecked="{Binding SelectedTabIndex, Converter={StaticResource IntEqualsBoolConverter}, ConverterParameter=0}">
                        <TextBlock Text="隧道" />
                    </RadioButton>
                    <RadioButton Style="{StaticResource TopNavItemStyle}"
                                 GroupName="MainNav"
                                 IsChecked="{Binding SelectedTabIndex, Converter={StaticResource IntEqualsBoolConverter}, ConverterParameter=1}">
                        <TextBlock Text="配置" />
                    </RadioButton>
                    <RadioButton Style="{StaticResource TopNavItemStyle}"
                                 GroupName="MainNav"
                                 IsChecked="{Binding SelectedTabIndex, Converter={StaticResource IntEqualsBoolConverter}, ConverterParameter=2}">
                        <TextBlock Text="活动日志" />
                    </RadioButton>
                    <RadioButton Style="{StaticResource TopNavItemStyle}"
                                 GroupName="MainNav"
                                 IsChecked="{Binding SelectedTabIndex, Converter={StaticResource IntEqualsBoolConverter}, ConverterParameter=3}">
                        <TextBlock Text="工具" />
                    </RadioButton>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Border Style="{StaticResource ShellStatusPillStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="6" Height="6" Margin="0,0,7,0" VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{StaticResource StatusStoppedBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RuntimeStatus}" Value="运行时已就绪">
                                                <Setter Property="Fill" Value="{StaticResource StatusRunningBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="{Binding RuntimeStatus}"
                                       FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource ShellStatusPillStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="6" Height="6" Margin="0,0,7,0" VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{StaticResource StatusStartingBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding PrivilegeStatus}" Value="已使用管理员权限运行">
                                                <Setter Property="Fill" Value="{StaticResource StatusRunningBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="{Binding PrivilegeStatus}"
                                       FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1"
                    SelectedIndex="{Binding SelectedTabIndex}"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0">
            <TabControl.Template>
                <ControlTemplate TargetType="TabControl">
                    <ContentPresenter ContentSource="SelectedContent" />
                </ControlTemplate>
            </TabControl.Template>

            <!-- Tunnels -->
            <TabItem>
                <Grid Margin="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Style="{StaticResource PanelCardStyle}"
                            Padding="12"
                            Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0"
                                        Margin="0,0,14,0"
                                        VerticalAlignment="Center">
                                <TextBlock Text="隧道工作台"
                                           FontSize="16"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{Binding SelectedTunnel.ConfigPath, TargetNullValue='选择隧道后显示配置路径'}"
                                           FontSize="10"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,2,0,0"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="310" />
                            </StackPanel>

                            <TabControl Grid.Column="1"
                                        ItemsSource="{Binding Tunnels}"
                                        SelectedItem="{Binding SelectedTunnel}"
                                        Style="{StaticResource TunnelTabControlStyle}"
                                        ItemContainerStyle="{StaticResource TunnelTabItemStyle}"
                                        VerticalAlignment="Center">
                                <TabControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Ellipse Grid.Column="0"
                                                     Width="7"
                                                     Height="7"
                                                     Margin="0,0,7,0"
                                                     VerticalAlignment="Center">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="{StaticResource StatusStoppedBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Started">
                                                                <Setter Property="Fill" Value="{StaticResource StatusRunningBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Starting">
                                                                <Setter Property="Fill" Value="{StaticResource StatusStartingBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Stopping">
                                                                <Setter Property="Fill" Value="{StaticResource StatusStoppingBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Name}"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center" />
                                        </Grid>
                                    </DataTemplate>
                                </TabControl.ItemTemplate>
                            </TabControl>

                            <StackPanel Grid.Column="2"
                                        Orientation="Horizontal"
                                        Margin="14,0,0,0"
                                        VerticalAlignment="Center">
                                <Button Content="刷新"
                                        Command="{Binding RefreshCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Width="74"
                                        Padding="10,6"
                                        Margin="0,0,8,0" />
                                <Button Content="导入 .conf"
                                        Command="{Binding ImportCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Padding="12,6" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="300" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Grid.ColumnSpan="3"
                                   Text="请选择一个隧道以查看详情。"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="13">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedTunnel}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <Border Grid.Column="0">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource PanelCardStyle}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedTunnel}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <StackPanel Margin="14">
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding SelectedTunnel.Name}"
                                                       FontSize="20"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding SelectedTunnel.AddressDisplay}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Margin="0,3,0,0"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                        <Border Grid.Column="1"
                                                Margin="10,0,0,0"
                                                Padding="8,3"
                                                CornerRadius="5"
                                                VerticalAlignment="Top">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#1E293B" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedTunnel.Status}" Value="Started">
                                                            <Setter Property="Background" Value="#14532D" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedTunnel.Status}" Value="Starting">
                                                            <Setter Property="Background" Value="#713F12" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedTunnel.Status}" Value="Stopping">
                                                            <Setter Property="Background" Value="#7C2D12" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding SelectedTunnel.StatusDisplay}"
                                                       FontSize="10"
                                                       FontWeight="SemiBold" />
                                        </Border>
                                    </Grid>

                                    <UniformGrid Columns="2" Margin="0,0,0,12">
                                        <Button Content="{Binding ToggleTunnelButtonContent}"
                                                Command="{Binding ToggleTunnelCommand}"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                Margin="0,0,6,6"
                                                Padding="10,7" />
                                        <Button Content="编辑配置"
                                                Command="{Binding EditConfigCommand}"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Margin="0,0,0,6"
                                                Padding="10,7" />
                                        <Button Content="导出"
                                                Command="{Binding ExportCommand}"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Margin="0,0,6,0"
                                                Padding="10,7" />
                                        <Button Content="删除"
                                                Command="{Binding RemoveCommand}"
                                                Style="{StaticResource DangerButtonStyle}"
                                                Padding="10,7" />
                                    </UniformGrid>

                                    <Border Height="1"
                                            Background="{StaticResource BorderBrush}"
                                            Margin="0,0,0,12" />

                                    <TextBlock Text="配置摘要"
                                               Style="{StaticResource SectionTitleStyle}"
                                               Margin="0,0,0,10" />
                                    <TextBlock Text="DNS" Style="{StaticResource InfoLabelStyle}" />
                                    <TextBlock Text="{Binding SelectedTunnel.DnsDisplay}"
                                               Style="{StaticResource InfoValueStyle}"
                                               Margin="0,0,0,10" />
                                    <TextBlock Text="对等端" Style="{StaticResource InfoLabelStyle}" />
                                    <TextBlock Text="{Binding SelectedTunnel.PeerCount}"
                                               Style="{StaticResource InfoValueStyle}"
                                               Margin="0,0,0,10" />
                                    <TextBlock Text="端点" Style="{StaticResource InfoLabelStyle}" />
                                    <TextBlock Text="{Binding SelectedTunnel.EndpointDisplay}"
                                               Style="{StaticResource InfoValueStyle}"
                                               Margin="0,0,0,10" />
                                    <TextBlock Text="配置文件" Style="{StaticResource InfoLabelStyle}" />
                                    <TextBlock Text="{Binding SelectedTunnel.ConfigPath}"
                                               Style="{StaticResource InfoValueStyle}" />
                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <Grid Grid.Column="2">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedTunnel}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Style="{StaticResource PanelCardStyle}"
                                    Padding="12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <WrapPanel Grid.Column="0"
                                               VerticalAlignment="Center">
                                        <TextBlock Text="网段"
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center" />
                                        <Border Margin="7,0,14,0"
                                                Padding="8,3"
                                                Background="{StaticResource PanelElevatedBrush}"
                                                BorderBrush="{StaticResource BorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="5">
                                            <TextBlock Text="{Binding TunnelNeighbors.SubnetDisplay}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold" />
                                        </Border>
                                        <TextBlock Text="状态"
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center" />
                                        <Border Margin="7,0,14,0"
                                                Padding="8,3"
                                                Background="{StaticResource PanelElevatedBrush}"
                                                BorderBrush="{StaticResource BorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="5">
                                            <TextBlock Text="{Binding TunnelNeighbors.StatusSummary}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold" />
                                        </Border>
                                        <TextBlock Text="{Binding TunnelNeighbors.LastScanDisplay, StringFormat=最近扫描: {0}}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                    </WrapPanel>

                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal"
                                                Margin="12,0,0,0">
                                        <Button Content="取消"
                                                Command="{Binding TunnelNeighbors.CancelScanCommand}"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Width="72"
                                                Padding="10,6"
                                                Margin="0,0,8,0" />
                                        <Button Content="扫描网段"
                                                Command="{Binding TunnelNeighbors.ScanCommand}"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                Width="88"
                                                Padding="10,6" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <UniformGrid Grid.Row="1"
                                         Margin="0,10,0,10"
                                         Columns="4">
                                <Border Style="{StaticResource MetricChipStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding TunnelNeighbors.OnlineCount}"
                                                   Style="{StaticResource MetricValueStyle}"
                                                   Foreground="{StaticResource StatusRunningBrush}" />
                                        <TextBlock Text="在线"
                                                   Style="{StaticResource SectionTitleStyle}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricChipStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding TunnelNeighbors.OfflineCount}"
                                                   Style="{StaticResource MetricValueStyle}"
                                                   Foreground="{StaticResource DangerBrush}" />
                                        <TextBlock Text="离线"
                                                   Style="{StaticResource SectionTitleStyle}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricChipStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding TunnelNeighbors.UnassignedCount}"
                                                   Style="{StaticResource MetricValueStyle}"
                                                   Foreground="{StaticResource StatusStoppingBrush}" />
                                        <TextBlock Text="未分配"
                                                   Style="{StaticResource SectionTitleStyle}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricChipStyle}"
                                        Margin="0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding TunnelNeighbors.HostnameResolvedCount}"
                                                   Style="{StaticResource MetricValueStyle}"
                                                   Foreground="{StaticResource AccentBrush}" />
                                        <TextBlock Text="解析成功"
                                                   Style="{StaticResource SectionTitleStyle}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <Border Grid.Row="2"
                                    Style="{StaticResource PanelCardStyle}">
                                <Grid>
                                    <DataGrid ItemsSource="{Binding TunnelNeighbors.Hosts}"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              CanUserDeleteRows="False"
                                              HeadersVisibility="Column"
                                              GridLinesVisibility="Horizontal"
                                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                              IsReadOnly="False"
                                              RowHeight="36"
                                              ColumnHeaderHeight="32">
                                        <DataGrid.Resources>
                                            <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                                                <Setter Property="Padding" Value="8,0" />
                                            </Style>
                                            <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                                <Setter Property="Padding" Value="8,0" />
                                            </Style>
                                        </DataGrid.Resources>
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Width="150"
                                                                Header="备注名"
                                                                Binding="{Binding Remark, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                            <DataGridTextColumn Width="132"
                                                                Header="IP"
                                                                Binding="{Binding IpAddress}"
                                                                SortMemberPath="IpAddressLastSegmentSortKey"
                                                                IsReadOnly="True" />
                                            <DataGridTextColumn Width="*"
                                                                Header="真实主机名"
                                                                Binding="{Binding HostnameDisplay}"
                                                                IsReadOnly="True" />
                                            <DataGridTemplateColumn Width="86"
                                                                    Header="Ping"
                                                                    SortMemberPath="PingMs">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Border Tag="{Binding PingBadgeKind}"
                                                                Style="{StaticResource CompactBadgeBorderStyle}"
                                                                HorizontalAlignment="Center">
                                                            <TextBlock Text="{Binding PingBadgeText}"
                                                                       Style="{StaticResource CompactBadgeTextStyle}" />
                                                        </Border>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Width="92"
                                                                    Header="端口">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Grid>
                                                            <StackPanel Orientation="Horizontal"
                                                                        HorizontalAlignment="Center">
                                                                <Border Margin="0,0,4,0">
                                                                    <Border.Style>
                                                                        <Style TargetType="Border" BasedOn="{StaticResource CompactBadgeBorderStyle}">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                            <Setter Property="Tag" Value="success" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsRdpOpen}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Border.Style>
                                                                    <TextBlock Text="RDP"
                                                                               Style="{StaticResource CompactBadgeTextStyle}" />
                                                                </Border>
                                                                <Border>
                                                                    <Border.Style>
                                                                        <Style TargetType="Border" BasedOn="{StaticResource CompactBadgeBorderStyle}">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                            <Setter Property="Tag" Value="success" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsSshOpen}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Border.Style>
                                                                    <TextBlock Text="SSH"
                                                                               Style="{StaticResource CompactBadgeTextStyle}" />
                                                                </Border>
                                                            </StackPanel>
                                                            <TextBlock Text="-"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       Foreground="{StaticResource TextSecondaryBrush}">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding HasOpenPorts}" Value="True">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Grid>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Width="82"
                                                                    Header="状态"
                                                                    SortMemberPath="StatusDisplay">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Border Tag="{Binding StatusBadgeKind}"
                                                                Style="{StaticResource CompactBadgeBorderStyle}"
                                                                HorizontalAlignment="Center">
                                                            <TextBlock Text="{Binding StatusBadgeText}"
                                                                       Style="{StaticResource CompactBadgeTextStyle}" />
                                                        </Border>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTextColumn Width="150"
                                                                Header="最后发现"
                                                                Binding="{Binding LastSeenDisplay}"
                                                                IsReadOnly="True" />
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <TextBlock Text="{Binding TunnelNeighbors.EmptyStateText}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="13"
                                               IsHitTestVisible="False" />
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Configuration -->
            <TabItem>
                <Grid Margin="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Style="{StaticResource PanelCardStyle}"
                            Padding="12"
                            Margin="0,0,0,12">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Right"
                                        Orientation="Horizontal">
                                <Button Content="保存"
                                        Command="{Binding SaveCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Width="76"
                                        Padding="10,6"
                                        Margin="0,0,8,0" />
                                <Button Content="导出"
                                        Command="{Binding ExportCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Width="76"
                                        Padding="10,6" />
                            </StackPanel>
                            <StackPanel DockPanel.Dock="Left"
                                        VerticalAlignment="Center">
                                <TextBlock Text="配置编辑器"
                                           FontSize="16"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{Binding SelectedTunnel.Name, TargetNullValue='未选择隧道'}"
                                           FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,2,0,0" />
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <TextBox Grid.Row="1"
                             Text="{Binding EditableConfigText, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             TextWrapping="NoWrap"
                             FontFamily="Consolas"
                             FontSize="13"
                             Padding="16,12"
                             BorderThickness="1"
                             VerticalAlignment="Stretch"
                             HorizontalAlignment="Stretch" />

                    <Border Grid.Row="2"
                            Style="{StaticResource PanelCardStyle}"
                            Padding="12,8"
                            Margin="0,12,0,0">
                        <TextBlock Text="{Binding SelectedTunnel.ConfigPath, TargetNullValue='未选择隧道，请先前往“隧道”页面选择。'}"
                                   FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextTrimming="CharacterEllipsis" />
                    </Border>
                </Grid>
            </TabItem>

            <!-- Activity log -->
            <TabItem>
                <Grid Margin="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Style="{StaticResource PanelCardStyle}"
                            Padding="12"
                            Margin="0,0,0,12">
                        <DockPanel>
                            <Button DockPanel.Dock="Right"
                                    Content="清空"
                                    Command="{Binding ClearLogCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Width="76"
                                    Padding="10,6" />
                            <TextBlock Text="活动日志"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                        </DockPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Style="{StaticResource PanelCardStyle}">
                        <DataGrid ItemsSource="{Binding LogEntries}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  RowHeight="36"
                                  ColumnHeaderHeight="32">
                            <DataGrid.Columns>
                                <DataGridTextColumn Width="165"
                                                    Header="时间"
                                                    Binding="{Binding Timestamp}" />
                                <DataGridTextColumn Width="68"
                                                    Header="级别"
                                                    Binding="{Binding Level}">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                                            <Setter Property="VerticalAlignment" Value="Center" />
                                            <Style.Triggers>
                                                <Trigger Property="Text" Value="Error">
                                                    <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
                                                </Trigger>
                                                <Trigger Property="Text" Value="Warn">
                                                    <Setter Property="Foreground" Value="{StaticResource StatusStartingBrush}" />
                                                </Trigger>
                                                <Trigger Property="Text" Value="Info">
                                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Width="*"
                                                    Header="消息"
                                                    Binding="{Binding Message}" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Tools -->
            <TabItem>
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="420" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="0.7*" MinWidth="260" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0"
                                   Grid.ColumnSpan="3"
                                   Text="工具"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,12" />

                        <Border Grid.Row="1"
                                Grid.Column="0"
                                Style="{StaticResource PanelCardStyle}"
                                Padding="18">
                            <StackPanel>
                                <TextBlock Text="WireGuard 密钥对生成器"
                                           FontSize="14"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="为 WireGuard 配置生成新的公钥和私钥。"
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,5,0,12"
                                           TextWrapping="Wrap" />

                                <Button Content="生成新密钥对"
                                        Command="{Binding GenerateKeypairCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        HorizontalAlignment="Left"
                                        Padding="14,7" />

                                <TextBlock Text="公钥"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,16,0,5" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Text="{Binding GeneratedPublicKey, Mode=OneWay}"
                                             IsReadOnly="True"
                                             FontFamily="Consolas"
                                             FontSize="12" />
                                    <Button Grid.Column="1"
                                            Content="复制"
                                            Command="{Binding CopyPublicKeyCommand}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Margin="8,0,0,0"
                                            Width="62" />
                                </Grid>

                                <TextBlock Text="私钥"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,10,0,5" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Text="{Binding GeneratedPrivateKey, Mode=OneWay}"
                                             IsReadOnly="True"
                                             FontFamily="Consolas"
                                             FontSize="12" />
                                    <Button Grid.Column="1"
                                            Content="复制"
                                            Command="{Binding CopyPrivateKeyCommand}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Margin="8,0,0,0"
                                            Width="62" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1"
                                Grid.Column="2"
                                Style="{StaticResource PanelCardStyle}"
                                Padding="18">
                            <StackPanel>
                                <TextBlock Text="系统信息"
                                           FontSize="14"
                                           FontWeight="SemiBold" />
                                <Border Height="1"
                                        Background="{StaticResource BorderBrush}"
                                        Margin="0,12,0,12" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="96" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                               Text="运行时状态"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="12"
                                               Margin="0,0,0,10" />
                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                               Text="{Binding RuntimeStatus}"
                                               FontSize="12"
                                               Margin="0,0,0,10"
                                               TextWrapping="Wrap" />

                                    <TextBlock Grid.Row="1" Grid.Column="0"
                                               Text="权限级别"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="12" />
                                    <TextBlock Grid.Row="1" Grid.Column="1"
                                               Text="{Binding PrivilegeStatus}"
                                               FontSize="12"
                                               TextWrapping="Wrap" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
