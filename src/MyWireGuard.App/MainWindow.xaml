<Window x:Class="MyWireGuard.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="MyWireGuard"
        Height="720"
        Width="1180"
        MinHeight="600"
        MinWidth="960"
        Background="{StaticResource WindowBrush}"
        FontFamily="Microsoft YaHei UI"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True">

    <Window.Resources>
        <Style x:Key="DetailTabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid KeyboardNavigation.TabNavigation="Local">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Background="#161D2A"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="9"
                                    Padding="6">
                                <TabPanel IsItemsHost="True"
                                          Margin="0"
                                          Background="Transparent" />
                            </Border>

                            <ContentPresenter Grid.Row="1"
                                              Margin="0,12,0,0"
                                              ContentSource="SelectedContent" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DetailTabItemStyle" TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="18,9" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBg"
                                Margin="0,0,8,0"
                                Padding="{TemplateBinding Padding}"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="7">
                            <ContentPresenter x:Name="ContentSite"
                                              ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBg" Property="Background" Value="{StaticResource PanelElevatedBrush}" />
                                <Setter TargetName="TabBg" Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBg" Property="Background" Value="#202A3B" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="TabBg" Property="Background" Value="{StaticResource PanelElevatedBrush}" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ============================================================ -->
        <!--  SIDEBAR                                                      -->
        <!-- ============================================================ -->
        <DockPanel Grid.Column="0"
                   Background="{StaticResource SidebarBrush}">

            <!-- Logo / App Header -->
            <Border DockPanel.Dock="Top"
                    Padding="20,22,20,18"
                    BorderThickness="0,0,0,1"
                    BorderBrush="{StaticResource BorderBrush}">
                <StackPanel>
                    <TextBlock Text="MyWireGuard"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="WireGuard VPN 客户端"
                               FontSize="11"
                               Margin="0,3,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>
            </Border>

            <!-- Status Panel (pinned to bottom) -->
            <Border DockPanel.Dock="Bottom"
                    Padding="16,14"
                    BorderThickness="0,1,0,0"
                    BorderBrush="{StaticResource BorderBrush}">
                <StackPanel>
                    <!-- Runtime status row -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,7">
                        <Ellipse Width="6" Height="6"
                                 VerticalAlignment="Center"
                                 Margin="0,0,8,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{StaticResource StatusStoppedBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RuntimeStatus}" Value="运行时已就绪">
                                            <Setter Property="Fill" Value="{StaticResource StatusRunningBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding RuntimeStatus}"
                                   FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    <!-- Privilege status row -->
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="6" Height="6"
                                 VerticalAlignment="Center"
                                 Margin="0,0,8,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{StaticResource StatusStartingBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PrivilegeStatus}" Value="已使用管理员权限运行">
                                            <Setter Property="Fill" Value="{StaticResource StatusRunningBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding PrivilegeStatus}"
                                   FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Navigation Items -->
            <StackPanel DockPanel.Dock="Top" Margin="0,8,0,0">
                <RadioButton Style="{StaticResource NavItemStyle}"
                             GroupName="MainNav"
                             IsChecked="{Binding SelectedTabIndex, Converter={StaticResource IntEqualsBoolConverter}, ConverterParameter=0}">
                    <TextBlock Text="隧道" />
                </RadioButton>
                <RadioButton Style="{StaticResource NavItemStyle}"
                             GroupName="MainNav"
                             IsChecked="{Binding SelectedTabIndex, Converter={StaticResource IntEqualsBoolConverter}, ConverterParameter=1}">
                    <TextBlock Text="配置" />
                </RadioButton>
                <RadioButton Style="{StaticResource NavItemStyle}"
                             GroupName="MainNav"
                             IsChecked="{Binding SelectedTabIndex, Converter={StaticResource IntEqualsBoolConverter}, ConverterParameter=2}">
                    <TextBlock Text="活动日志" />
                </RadioButton>
                <RadioButton Style="{StaticResource NavItemStyle}"
                             GroupName="MainNav"
                             IsChecked="{Binding SelectedTabIndex, Converter={StaticResource IntEqualsBoolConverter}, ConverterParameter=3}">
                    <TextBlock Text="工具" />
                </RadioButton>
            </StackPanel>
        </DockPanel>

        <!-- Sidebar right-edge separator -->
        <Border Grid.Column="0"
                BorderThickness="0,0,1,0"
                BorderBrush="{StaticResource BorderBrush}"
                IsHitTestVisible="False" />

        <!-- ============================================================ -->
        <!--  MAIN CONTENT  (TabControl with hidden strip)                 -->
        <!-- ============================================================ -->
        <TabControl Grid.Column="1"
                    SelectedIndex="{Binding SelectedTabIndex}"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0">
            <TabControl.Template>
                <ControlTemplate TargetType="TabControl">
                    <ContentPresenter ContentSource="SelectedContent" />
                </ControlTemplate>
            </TabControl.Template>

            <!-- ======================================================== -->
            <!--  PAGE 0 — TUNNELS                                         -->
            <!-- ======================================================== -->
            <TabItem>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Page toolbar -->
                    <Border Grid.Row="0"
                            Padding="20,13"
                            Background="{StaticResource PanelBrush}"
                            BorderThickness="0,0,0,1"
                            BorderBrush="{StaticResource BorderBrush}">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left"
                                       Text="隧道"
                                       FontSize="17"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                            <StackPanel DockPanel.Dock="Right"
                                        Orientation="Horizontal">
                                <Button Content="刷新"
                                        Command="{Binding RefreshCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Width="86"
                                        Margin="0,0,8,0" />
                                <Button Content="+ 导入 .conf"
                                        Command="{Binding ImportCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Padding="14,7" />
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Tunnel list (left) + detail panel (right) -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Tunnel list -->
                        <Border Grid.Column="0"
                                Background="{StaticResource PanelBrush}"
                                BorderThickness="0,0,1,0"
                                BorderBrush="{StaticResource BorderBrush}">
                            <ListBox ItemsSource="{Binding Tunnels}"
                                     SelectedItem="{Binding SelectedTunnel}"
                                     Padding="4,4">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Height="58">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="18" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <!-- Status indicator dot -->
                                            <Ellipse Grid.Column="0"
                                                     Width="8" Height="8"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="{StaticResource StatusStoppedBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Started">
                                                                <Setter Property="Fill" Value="{StaticResource StatusRunningBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Starting">
                                                                <Setter Property="Fill" Value="{StaticResource StatusStartingBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Stopping">
                                                                <Setter Property="Fill" Value="{StaticResource StatusStoppingBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <!-- Tunnel name + info -->
                                            <StackPanel Grid.Column="1"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}"
                                                           FontWeight="SemiBold"
                                                           FontSize="13" />
                                                <TextBlock Text="{Binding AddressDisplay}"
                                                           FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           Margin="0,2,0,0"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding StatusDisplay}"
                                                           FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           Margin="0,1,0,0" />
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>

                        <!-- Detail panel (right side) -->
                        <Grid Grid.Column="1">

                            <!-- Empty-state hint (visible when no tunnel selected) -->
                            <TextBlock Text="请选择一个隧道以查看详情。"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="13">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedTunnel}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- Tunnel detail content -->
                            <Grid Margin="28,24,28,24">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedTunnel}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <WrapPanel Grid.Row="0" Margin="0,0,0,20">
                                    <Button Content="{Binding ToggleTunnelButtonContent}"
                                            Command="{Binding ToggleTunnelCommand}"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Width="90"
                                            Margin="0,0,8,0" />
                                    <Button Content="✎  编辑配置"
                                            Command="{Binding EditConfigCommand}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Width="112"
                                            Margin="0,0,8,0" />
                                    <Button Content="导出"
                                            Command="{Binding ExportCommand}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Width="86"
                                            Margin="0,0,8,0" />
                                    <Button Content="删除"
                                            Command="{Binding RemoveCommand}"
                                            Style="{StaticResource DangerButtonStyle}"
                                            Width="86" />
                                </WrapPanel>

                                <StackPanel Grid.Row="1" Margin="0,0,0,20">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding SelectedTunnel.Name}"
                                                   FontSize="22"
                                                   FontWeight="SemiBold" />
                                        <Border Margin="12,0,0,0"
                                                Padding="8,3"
                                                CornerRadius="4"
                                                VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#1A546E7A" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedTunnel.Status}" Value="Started">
                                                            <Setter Property="Background" Value="#1A4CAF50" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedTunnel.Status}" Value="Starting">
                                                            <Setter Property="Background" Value="#1AFFA726" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedTunnel.Status}" Value="Stopping">
                                                            <Setter Property="Background" Value="#1AFF7043" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding SelectedTunnel.StatusDisplay}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource StatusStoppedBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedTunnel.Status}" Value="Started">
                                                                <Setter Property="Foreground" Value="{StaticResource StatusRunningBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding SelectedTunnel.Status}" Value="Starting">
                                                                <Setter Property="Foreground" Value="{StaticResource StatusStartingBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding SelectedTunnel.Status}" Value="Stopping">
                                                                <Setter Property="Foreground" Value="{StaticResource StatusStoppingBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>

                                <TabControl Grid.Row="2"
                                        Style="{StaticResource DetailTabControlStyle}">
                                    <TabItem Header="简介"
                                         Style="{StaticResource DetailTabItemStyle}">
                                        <Border Padding="0,10,0,0"
                                                Background="Transparent">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="130" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="地址"
                                                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,10" />
                                                <TextBlock Grid.Row="0" Grid.Column="1"
                                                           Text="{Binding SelectedTunnel.AddressDisplay}"
                                                           FontSize="12" Margin="0,0,0,10" />

                                                <TextBlock Grid.Row="1" Grid.Column="0" Text="DNS"
                                                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,10" />
                                                <TextBlock Grid.Row="1" Grid.Column="1"
                                                           Text="{Binding SelectedTunnel.DnsDisplay}"
                                                           FontSize="12" Margin="0,0,0,10" />

                                                <TextBlock Grid.Row="2" Grid.Column="0" Text="对等端"
                                                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,10" />
                                                <TextBlock Grid.Row="2" Grid.Column="1"
                                                           Text="{Binding SelectedTunnel.PeerCount}"
                                                           FontSize="12" Margin="0,0,0,10" />

                                                <TextBlock Grid.Row="3" Grid.Column="0" Text="端点"
                                                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,10" />
                                                <TextBlock Grid.Row="3" Grid.Column="1"
                                                           Text="{Binding SelectedTunnel.EndpointDisplay}"
                                                           FontSize="12" Margin="0,0,0,10" />

                                                <TextBlock Grid.Row="4" Grid.Column="0" Text="配置文件"
                                                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
                                                <TextBlock Grid.Row="4" Grid.Column="1"
                                                           Text="{Binding SelectedTunnel.ConfigPath}"
                                                           FontSize="12"
                                                           TextTrimming="CharacterEllipsis" />
                                            </Grid>
                                        </Border>
                                    </TabItem>

                                    <TabItem Header="网段邻居"
                                             Style="{StaticResource DetailTabItemStyle}">
                                        <Grid Margin="0,10,0,0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>

                                            <Border Grid.Row="0"
                                                    Padding="16,14"
                                                    Background="{StaticResource PanelBrush}"
                                                    CornerRadius="8"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="1">
                                                <DockPanel LastChildFill="False">
                                                    <StackPanel DockPanel.Dock="Left"
                                                                Orientation="Horizontal"
                                                                VerticalAlignment="Center">
                                                        <TextBlock Text="网段"
                                                                   FontSize="12"
                                                                   Foreground="{StaticResource TextSecondaryBrush}" />
                                                        <Border Margin="8,0,12,0"
                                                                Padding="12,4"
                                                                Background="{StaticResource PanelElevatedBrush}"
                                                                CornerRadius="999">
                                                            <TextBlock Text="{Binding TunnelNeighbors.SubnetDisplay}"
                                                                       FontSize="13"
                                                                       FontWeight="SemiBold" />
                                                        </Border>
                                                        <TextBlock Text="状态"
                                                                   FontSize="12"
                                                                   Foreground="{StaticResource TextSecondaryBrush}" />
                                                        <Border Margin="8,0,0,0"
                                                                Padding="12,4"
                                                                Background="{StaticResource PanelElevatedBrush}"
                                                                CornerRadius="999">
                                                            <TextBlock Text="{Binding TunnelNeighbors.StatusSummary}"
                                                                       FontSize="13"
                                                                       FontWeight="SemiBold" />
                                                        </Border>
                                                    </StackPanel>

                                                    <StackPanel DockPanel.Dock="Right"
                                                                Orientation="Horizontal">
                                                        <Button Content="取消"
                                                                Command="{Binding TunnelNeighbors.CancelScanCommand}"
                                                                Style="{StaticResource SecondaryButtonStyle}"
                                                                Width="86"
                                                                Margin="0,0,8,0" />
                                                        <Button Content="扫描网段"
                                                                Command="{Binding TunnelNeighbors.ScanCommand}"
                                                                Style="{StaticResource PrimaryButtonStyle}"
                                                                Width="96" />
                                                    </StackPanel>
                                                </DockPanel>
                                            </Border>

                                            <UniformGrid Grid.Row="1"
                                                         Margin="0,14,0,12"
                                                         Columns="4">
                                                <Border Margin="0,0,12,0"
                                                        Padding="14,12"
                                                        Background="{StaticResource PanelBrush}"
                                                        CornerRadius="8"
                                                        BorderBrush="{StaticResource BorderBrush}"
                                                        BorderThickness="1">
                                                    <StackPanel>
                                                        <TextBlock Text="在线"
                                                                   FontSize="12"
                                                                   Foreground="{StaticResource TextSecondaryBrush}" />
                                                        <TextBlock Text="{Binding TunnelNeighbors.OnlineCount}"
                                                                   Margin="0,6,0,0"
                                                                   FontSize="28"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource StatusRunningBrush}" />
                                                    </StackPanel>
                                                </Border>
                                                <Border Margin="0,0,12,0"
                                                        Padding="14,12"
                                                        Background="{StaticResource PanelBrush}"
                                                        CornerRadius="8"
                                                        BorderBrush="{StaticResource BorderBrush}"
                                                        BorderThickness="1">
                                                    <StackPanel>
                                                        <TextBlock Text="离线"
                                                                   FontSize="12"
                                                                   Foreground="{StaticResource TextSecondaryBrush}" />
                                                        <TextBlock Text="{Binding TunnelNeighbors.OfflineCount}"
                                                                   Margin="0,6,0,0"
                                                                   FontSize="28"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource DangerBrush}" />
                                                    </StackPanel>
                                                </Border>
                                                <Border Margin="0,0,12,0"
                                                        Padding="14,12"
                                                        Background="{StaticResource PanelBrush}"
                                                        CornerRadius="8"
                                                        BorderBrush="{StaticResource BorderBrush}"
                                                        BorderThickness="1">
                                                    <StackPanel>
                                                        <TextBlock Text="未分配"
                                                                   FontSize="12"
                                                                   Foreground="{StaticResource TextSecondaryBrush}" />
                                                        <TextBlock Text="{Binding TunnelNeighbors.UnassignedCount}"
                                                                   Margin="0,6,0,0"
                                                                   FontSize="28"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource StatusStoppingBrush}" />
                                                    </StackPanel>
                                                </Border>
                                                <Border Padding="14,12"
                                                        Background="{StaticResource PanelBrush}"
                                                        CornerRadius="8"
                                                        BorderBrush="{StaticResource BorderBrush}"
                                                        BorderThickness="1">
                                                    <StackPanel>
                                                        <TextBlock Text="解析成功"
                                                                   FontSize="12"
                                                                   Foreground="{StaticResource TextSecondaryBrush}" />
                                                        <TextBlock Text="{Binding TunnelNeighbors.HostnameResolvedCount}"
                                                                   Margin="0,6,0,0"
                                                                   FontSize="28"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource AccentBrush}" />
                                                    </StackPanel>
                                                </Border>
                                            </UniformGrid>

                                            <TextBlock Grid.Row="2"
                                                       Text="{Binding TunnelNeighbors.LastScanDisplay, StringFormat=最近扫描: {0}}"
                                                       Margin="0,0,0,10"
                                                       FontSize="12"
                                                       Foreground="{StaticResource TextSecondaryBrush}" />

                                            <Grid Grid.Row="3">
                                                <DataGrid ItemsSource="{Binding TunnelNeighbors.Hosts}"
                                                          AutoGenerateColumns="False"
                                                          CanUserAddRows="False"
                                                          CanUserDeleteRows="False"
                                                          HeadersVisibility="Column"
                                                          GridLinesVisibility="Horizontal"
                                                          IsReadOnly="False">
                                                    <DataGrid.Columns>
                                                        <DataGridTextColumn Width="170"
                                                                            Header="备注名"
                                                                            Binding="{Binding Remark, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                                        <DataGridTextColumn Width="150"
                                                                            Header="IP"
                                                                            Binding="{Binding IpAddress}"
                                                                            SortMemberPath="IpAddressLastSegmentSortKey"
                                                                            IsReadOnly="True" />
                                                        <DataGridTextColumn Width="*"
                                                                            Header="真实主机名"
                                                                            Binding="{Binding HostnameDisplay}"
                                                                            IsReadOnly="True" />
                                                        <DataGridTemplateColumn Width="104"
                                                                                Header="Ping"
                                                                                SortMemberPath="PingMs">
                                                            <DataGridTemplateColumn.CellTemplate>
                                                                <DataTemplate>
                                                                    <Border Tag="{Binding PingBadgeKind}"
                                                                            Style="{StaticResource BadgeBorderStyle}"
                                                                            HorizontalAlignment="Center">
                                                                        <TextBlock Text="{Binding PingBadgeText}"
                                                                                   Style="{StaticResource BadgeTextStyle}" />
                                                                    </Border>
                                                                </DataTemplate>
                                                            </DataGridTemplateColumn.CellTemplate>
                                                        </DataGridTemplateColumn>
                                                        <DataGridTemplateColumn Width="110"
                                                                                Header="端口">
                                                            <DataGridTemplateColumn.CellTemplate>
                                                                <DataTemplate>
                                                                    <Grid>
                                                                        <StackPanel Orientation="Horizontal"
                                                                                    HorizontalAlignment="Center">
                                                                            <Border Margin="0,0,6,0">
                                                                                <Border.Style>
                                                                                    <Style TargetType="Border" BasedOn="{StaticResource SmallBadgeBorderStyle}">
                                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                                        <Setter Property="Tag" Value="success" />
                                                                                        <Style.Triggers>
                                                                                            <DataTrigger Binding="{Binding IsRdpOpen}" Value="True">
                                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                                            </DataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </Border.Style>
                                                                                <TextBlock Text="RDP"
                                                                                           Style="{StaticResource BadgeTextStyle}" />
                                                                            </Border>
                                                                            <Border>
                                                                                <Border.Style>
                                                                                    <Style TargetType="Border" BasedOn="{StaticResource SmallBadgeBorderStyle}">
                                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                                        <Setter Property="Tag" Value="success" />
                                                                                        <Style.Triggers>
                                                                                            <DataTrigger Binding="{Binding IsSshOpen}" Value="True">
                                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                                            </DataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </Border.Style>
                                                                                <TextBlock Text="SSH"
                                                                                           Style="{StaticResource BadgeTextStyle}" />
                                                                            </Border>
                                                                        </StackPanel>
                                                                        <TextBlock Text="-"
                                                                                   HorizontalAlignment="Center"
                                                                                   VerticalAlignment="Center"
                                                                                   Foreground="{StaticResource TextSecondaryBrush}">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding HasOpenPorts}" Value="True">
                                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>
                                                                    </Grid>
                                                                </DataTemplate>
                                                            </DataGridTemplateColumn.CellTemplate>
                                                        </DataGridTemplateColumn>
                                                        <DataGridTemplateColumn Width="96"
                                                                                Header="状态"
                                                                                SortMemberPath="StatusDisplay">
                                                            <DataGridTemplateColumn.CellTemplate>
                                                                <DataTemplate>
                                                                    <Border Tag="{Binding StatusBadgeKind}"
                                                                            Style="{StaticResource BadgeBorderStyle}"
                                                                            HorizontalAlignment="Center">
                                                                        <TextBlock Text="{Binding StatusBadgeText}"
                                                                                   Style="{StaticResource BadgeTextStyle}" />
                                                                    </Border>
                                                                </DataTemplate>
                                                            </DataGridTemplateColumn.CellTemplate>
                                                        </DataGridTemplateColumn>
                                                        <DataGridTextColumn Width="170"
                                                                            Header="最后发现"
                                                                            Binding="{Binding LastSeenDisplay}"
                                                                            IsReadOnly="True" />
                                                    </DataGrid.Columns>
                                                </DataGrid>

                                                <TextBlock Text="{Binding TunnelNeighbors.EmptyStateText}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           FontSize="13"
                                                           IsHitTestVisible="False" />
                                            </Grid>
                                        </Grid>
                                    </TabItem>
                                </TabControl>
                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ======================================================== -->
            <!--  PAGE 1 — CONFIGURATION                                   -->
            <!-- ======================================================== -->
            <TabItem>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <Border Grid.Row="0"
                            Padding="20,13"
                            Background="{StaticResource PanelBrush}"
                            BorderThickness="0,0,0,1"
                            BorderBrush="{StaticResource BorderBrush}">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Right"
                                        Orientation="Horizontal">
                                <Button Content="保存"
                                        Command="{Binding SaveCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Width="80"
                                        Margin="0,0,8,0" />
                                <Button Content="导出"
                                        Command="{Binding ExportCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Width="80" />
                            </StackPanel>
                            <StackPanel DockPanel.Dock="Left"
                                        VerticalAlignment="Center">
                                <TextBlock Text="配置编辑器"
                                           FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                <TextBlock Text="{Binding SelectedTunnel.Name, TargetNullValue='(未选择隧道)'}"
                                           FontSize="17"
                                           FontWeight="SemiBold"
                                           Margin="0,2,0,0" />
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Config text editor -->
                    <TextBox Grid.Row="1"
                             Text="{Binding EditableConfigText, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             TextWrapping="NoWrap"
                             FontFamily="Consolas"
                             FontSize="13"
                             Padding="20,16"
                             BorderThickness="0"
                             VerticalAlignment="Stretch"
                             HorizontalAlignment="Stretch" />

                    <!-- Status bar -->
                    <Border Grid.Row="2"
                            Padding="20,8"
                            Background="{StaticResource PanelBrush}"
                            BorderThickness="0,1,0,0"
                            BorderBrush="{StaticResource BorderBrush}">
                        <TextBlock Text="{Binding SelectedTunnel.ConfigPath, TargetNullValue='未选择隧道，请先前往“隧道”页面选择。'}"
                                   FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextTrimming="CharacterEllipsis" />
                    </Border>
                </Grid>
            </TabItem>

            <!-- ======================================================== -->
            <!--  PAGE 2 — ACTIVITY LOG                                    -->
            <!-- ======================================================== -->
            <TabItem>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0"
                            Padding="20,13"
                            Background="{StaticResource PanelBrush}"
                            BorderThickness="0,0,0,1"
                            BorderBrush="{StaticResource BorderBrush}">
                        <DockPanel>
                            <Button DockPanel.Dock="Right"
                                        Content="清空"
                                    Command="{Binding ClearLogCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Width="80" />
                                    <TextBlock Text="活动日志"
                                       FontSize="17"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                        </DockPanel>
                    </Border>

                    <!-- Log DataGrid -->
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding LogEntries}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTextColumn Width="165"
                                               Header="时间"
                                               Binding="{Binding Timestamp}" />
                            <DataGridTextColumn Width="68"
                                               Header="级别"
                                               Binding="{Binding Level}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="Error">
                                                <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
                                            </Trigger>
                                            <Trigger Property="Text" Value="Warn">
                                                <Setter Property="Foreground" Value="{StaticResource StatusStartingBrush}" />
                                            </Trigger>
                                            <Trigger Property="Text" Value="Info">
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Width="*"
                                               Header="消息"
                                               Binding="{Binding Message}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ======================================================== -->
            <!--  PAGE 3 — TOOLS                                           -->
            <!-- ======================================================== -->
            <TabItem>
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="28,24"
                                MaxWidth="640"
                                HorizontalAlignment="Left">

                        <TextBlock Text="工具"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,22" />

                        <!-- Keypair Generator Card -->
                        <Border Background="{StaticResource PanelBrush}"
                                CornerRadius="8"
                                Padding="22"
                                Margin="0,0,0,16"
                                BorderThickness="1"
                                BorderBrush="{StaticResource BorderBrush}">
                            <StackPanel>
                                <TextBlock Text="WireGuard 密钥对生成器"
                                           FontSize="14"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="为 WireGuard 配置生成新的公钥和私钥。"
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,6,0,16"
                                           TextWrapping="Wrap" />

                                <Button Content="生成新密钥对"
                                        Command="{Binding GenerateKeypairCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        HorizontalAlignment="Left"
                                        Padding="16,8" />

                                <!-- Public Key row -->
                                <TextBlock Text="公钥"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,20,0,6" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Text="{Binding GeneratedPublicKey, Mode=OneWay}"
                                             IsReadOnly="True"
                                             FontFamily="Consolas"
                                             FontSize="12" />
                                    <Button Grid.Column="1"
                                            Content="复制"
                                            Command="{Binding CopyPublicKeyCommand}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Margin="8,0,0,0"
                                            Width="66" />
                                </Grid>

                                <!-- Private Key row -->
                                <TextBlock Text="私钥"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,12,0,6" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Text="{Binding GeneratedPrivateKey, Mode=OneWay}"
                                             IsReadOnly="True"
                                             FontFamily="Consolas"
                                             FontSize="12" />
                                    <Button Grid.Column="1"
                                            Content="复制"
                                            Command="{Binding CopyPrivateKeyCommand}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Margin="8,0,0,0"
                                            Width="66" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- System Information Card -->
                        <Border Background="{StaticResource PanelBrush}"
                                CornerRadius="8"
                                Padding="22"
                                BorderThickness="1"
                                BorderBrush="{StaticResource BorderBrush}">
                            <StackPanel>
                                <TextBlock Text="系统信息"
                                           FontSize="14"
                                           FontWeight="SemiBold" />
                                <Border Height="1"
                                        Background="{StaticResource BorderBrush}"
                                        Margin="0,14,0,14" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                               Text="运行时状态"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="12"
                                               Margin="0,0,0,10" />
                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                               Text="{Binding RuntimeStatus}"
                                               FontSize="12"
                                               Margin="0,0,0,10" />

                                    <TextBlock Grid.Row="1" Grid.Column="0"
                                               Text="权限级别"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="12" />
                                    <TextBlock Grid.Row="1" Grid.Column="1"
                                               Text="{Binding PrivilegeStatus}"
                                               FontSize="12" />
                                </Grid>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
